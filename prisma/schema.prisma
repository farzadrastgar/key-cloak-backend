// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  password      String
  isVerified    Boolean      @default(false)
  refreshToken  String?      @default("null")
  roles         String[]     @default(["user"])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Character {
  id        Int       @id @default(autoincrement())
  name      String
  status    String
  species   String
  type      String?
  gender    String  
  image     Image     @relation(fields: [imageId], references: [id])
  imageId   Int       @unique
  location  Location  @relation(fields: [locationId], references: [id])
  locationId  Int
  origin    Location  @relation("Origin",fields: [originId], references: [id])
  originId  Int 
  episodes  Episode[] 
  characterEpisodes CharacterEpisode[]
  createdAt DateTime   @default(now())
}

model Location {
  id          Int       @id @default(autoincrement())
  name        String
  type        String
  dimension   String
  residents   Character[]  
  origin      Character[]  @relation("Origin")
  url         String
  createdAt   DateTime  @default(now())
}


model Image {
  id        Int       @id @default(autoincrement())
  fileName  String
  url       String
  character   Character?
  createdAt DateTime  @default(now())
}

model Episode {
  id          Int       @id @default(autoincrement())
  name        String
  air_date    String
  episode     String
  characters  Character[]
  characterEpisodes CharacterEpisode[]
  url         String
  createdAt   DateTime  @default(now())
}



model CharacterEpisode {
  characterId Int
  episodeId   Int

  character   Character @relation(fields: [characterId], references: [id])
  episode     Episode   @relation(fields: [episodeId], references: [id])

  @@id([characterId, episodeId])
}


