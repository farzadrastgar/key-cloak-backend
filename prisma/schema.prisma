generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  firstName    String?
  lastName     String?
  phoneNumber  String?
  password     String
  isVerified   Boolean  @default(false)
  refreshToken String?
  roles        String[] @default(["user"]) // global roles (optional)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  memberships  Membership[]
  invitations  Invitation[] @relation("UserInvitations")
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  // hierarchy
  parentId  String?
  parent    Organization?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children  Organization[] @relation("OrgHierarchy")

  // relations
  memberships Membership[]
  invitations Invitation[]
}

model Membership {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           String   @default("member") // org-specific role
  createdAt      DateTime @default(now())

  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId]) // prevents duplicates
}

model Invitation {
  id              String   @id @default(uuid())
  email           String
  organizationId  String
  token           String   @unique
  status          InvitationStatus @default(PENDING)
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  // optional: link if user already exists
  userId          String?
  user            User? @relation("UserInvitations", fields: [userId], references: [id])

  organization    Organization @relation(fields: [organizationId], references: [id])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

model AuthSettings {
  id            String  @id @default("global")
  password      Boolean @default(true)
  passkeys      Boolean @default(false)
  emailPasscode Boolean @default(false)
  mobile        Boolean @default(false)
}

model MfaSettings {
  id    String  @id @default("global")
  totp  Boolean @default(false)
  email Boolean @default(false)
  sms   Boolean @default(false)
}